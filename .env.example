# CLI Market Core - Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cli_market_core

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# External Services
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
WISE_API_KEY=your_wise_api_key
SHOPIFY_ACCESS_TOKEN=your_shopify_token
VTEX_APP_KEY=your_vtex_app_key
VTEX_APP_TOKEN=your_vtex_app_token

# SUNAT Invoicing
SUNAT_RUC=your_ruc
SUNAT_SOL_USER=your_sol_user
SUNAT_SOL_PASS=your_sol_pass

# AI/ML Services
MINIMAX_API_KEY=your_minimax_key

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/core.log

# Feature Flags
ENABLE_LIVE_DATA=false
ENABLE_MCP_TOOLS=true
