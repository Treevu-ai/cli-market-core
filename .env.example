# CLI Market Core - Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cli_market_core

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# External Services
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
WISE_API_KEY=your_wise_api_key
SHOPIFY_ACCESS_TOKEN=your_shopify_token
VTEX_APP_KEY=your_vtex_app_key
VTEX_APP_TOKEN=your_vtex_app_token

# SUNAT Invoicing (canonical names; Railway aliases in parentheses)
SUNAT_RUC=your_ruc                    # alias: SINAPSIS_RUC
SUNAT_SOL_USER=your_sol_user          # alias: CLAVE_SOL_TOKEN
SUNAT_SOL_PASS=your_sol_pass          # alias: PASSWORD_SUNAT_SINAPSIS
SUNAT_CLIENT_ID=your_consulta_client_id
SUNAT_CLIENT_SECRET=your_consulta_secret
# Nubefact PSE (Railway: PSE_SUNAT_ID=ruta UUID, PSE_SUNAT_PASSWORD=token)
SUNAT_PSE_ROUTE_ID=
SUNAT_PSE_API_KEY=
SUNAT_NUBEFACT_TOKEN=
SUNAT_PSE_API_URL=
SUNAT_PSE_PROVIDER=nubefact
SUNAT_MODE=production
SUNAT_BOLETA_SERIE=BBB1

# AI/ML Services
MINIMAX_API_KEY=your_minimax_key

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/core.log

# Feature Flags
ENABLE_LIVE_DATA=false
ENABLE_MCP_TOOLS=true
