+import Link from "next/link";
+import type { Metadata } from "next";
+
+export const metadata: Metadata = {
+  title: "Pago cancelado — Procure Copilot",
+  description: "El checkout de Procure Copilot fue cancelado.",
+};
+
+export default function CheckoutCancelPage() {
+  return (
+    <main className="min-h-screen bg-[#0a0f0d] text-[#e8f5f0] flex items-center justify-center p-6">
+      <div className="max-w-lg w-full rounded-2xl border border-[#1e2e28] bg-[#0f1613] p-8 text-center">
+        <p className="text-[#3afecf] text-sm font-mono mb-2">PROCURE COPILOT</p>
+        <h1 className="text-2xl font-semibold mb-3">Checkout cancelado</h1>
+        <p className="text-[#b9cac2] mb-6">
