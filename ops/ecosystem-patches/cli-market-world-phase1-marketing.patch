@@ -0,0 +1,71 @@
+"""Phase 0/1 — sync_market_stats marketing alignment tests."""
+
+from __future__ import annotations
+
+import json
+import sys
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parent.parent
+LANDING = ROOT / "landing"
+sys.path.insert(0, str(ROOT))
+sys.path.insert(0, str(ROOT.parent / "cli-market-core"))
+
+from ops.sync_market_stats import _CANONICAL_HIGHLIGHTS, _bundle_tools_for_landing
+from market_core.market_mcp_registry import public_tool_count
+
+
+def test_default_mcp_tool_count_is_32():
+    assert public_tool_count("default") == 32
+
+
+def test_shop_canonical_is_optimize_purchase():
+    assert "market_optimize_purchase" in _CANONICAL_HIGHLIGHTS
+    assert "market_discover" not in _CANONICAL_HIGHLIGHTS
+    shop = _bundle_tools_for_landing("default")["shop"]
+    canonical = [t for t in shop if t["canonical"]]
+    assert canonical and canonical[0]["id"] == "market_optimize_purchase"
+
+
+def test_market_stats_ts_generated():
+    text = (LANDING / "lib/marketStats.ts").read_text(encoding="utf-8")
+    assert "mcpTools: 32" in text
+    assert 'packageVersion: "1.11.0"' in text
+    assert '"canonical": true' in text
+    assert "market_optimize_purchase" in text
+
+
+def test_sync_llms_full_bundle_includes_optimize_purchase():
+    from ops.sync_market_stats import sync_llms_txt
+
+    sync_llms_txt()
+    text = (LANDING / "public/llms-full.txt").read_text(encoding="utf-8")
+    assert "market_optimize_purchase" in text
+    assert "market_discover" in text
+    shop_block = text.split("## MCP tool bundles")[1].split("## Countries:")[0]
+    assert "Canonical: market_optimize_purchase" in shop_block
+
+
+def test_sync_llms_txt_phase1():
+    from ops.sync_market_stats import sync_llms_txt
+
+    sync_llms_txt()
+    text = (LANDING / "public/llms.txt").read_text(encoding="utf-8")
+    assert "32 curated MCP tools" in text
+    assert "market optimize" in text
+    assert "27 curated MCP" not in text
+    assert "61,000+" not in text
+    assert "default agent flow" in text.lower()
+
+
+def test_sync_agents_json_phase1():
+    from ops.sync_market_stats import sync_agents_json
+
+    sync_agents_json()
+    data = json.loads((LANDING / "public/agents.json").read_text(encoding="utf-8"))
+    assert data["version"] == "1.11.0"
+    assert "optimize_purchase" in data["capabilities"]
+    assert "stock_check" not in data["capabilities"]
+    assert data["agent_flows"]["procurement"][0] == "market_optimize_purchase"
+    assert data["data_freshness"]["stock"] == "4h"
+    assert data["pricing"]["starter"]["requests_per_day"] == 5000
