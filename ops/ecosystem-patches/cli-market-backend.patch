@@ -667,6 +667,7 @@ async def fetch_store_multi(client, store, term):
 # ── Full catalog download ───────────────────────────────────────────────────
 
 CATALOG_INTERVAL_MINS = int(os.getenv("COLLECT_CATALOG_INTERVAL", "60"))
+CATALOG_STORES_PER_CYCLE = int(os.getenv("CATALOG_STORES_PER_CYCLE", "10"))
 _last_catalog_pull: float = 0.0
 
 async def collect_full_catalog_pg(pool, store: str) -> int:
@@ -743,6 +744,28 @@ async def run_full_catalog_pg(pool, stores: list[str], *, force: bool = False) -
     return total
 
 
+async def run_rotating_catalog_pg(pool, stores: list[str], cycle: int) -> int:
+    """Refresh full catalog for a rotating subset each cycle — improves moat freshness without one huge batch."""
+    from store_credentials import resolve_store_config
+
+    eligible = [
+        s for s in stores
+        if resolve_store_config(s).get("platform") in ("vtex", "woocommerce")
+    ]
+    if not eligible:
+        return 0
+    batch_size = max(1, min(CATALOG_STORES_PER_CYCLE, len(eligible)))
+    start = (cycle * batch_size) % len(eligible)
+    batch = [eligible[(start + i) % len(eligible)] for i in range(batch_size)]
+    total = 0
+    for store in batch:
+        n = await collect_full_catalog_pg(pool, store)
+        if n:
+            print(f"    📦 {store}: {n:,} products (rotating catalog)")
+        total += n
+    return total
+
+
 
 async def force_catalog_stores(stores: list[str]) -> dict:
     """Bypass catalog interval and upsert full catalog for given stores."""
